# Ambiente da API
NODE_ENV=development
HOST=127.0.0.1
PORT=8000
API_PREFIX=/api
REQUEST_BODY_LIMIT=8mb

# CORS local/offline
# Separe varias origens por virgula.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
CORS_ALLOW_LOCALHOST=true

# Firebird 2.5
FIREBIRD_HOST=127.0.0.1
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:\caminho\para\banco.fdb
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey
FIREBIRD_ROLE=
FIREBIRD_CHARSET=WIN1252
FIREBIRD_PAGE_SIZE=4096
FIREBIRD_POOL_MAX=5
FIREBIRD_CONNECT_TIMEOUT_MS=10000

# Fotos de evidência das inspeções manuais
UPLOAD_DIR=uploads

# Token retornado na autenticação por Face ID
JWT_SECRET=altere_este_valor_em_producao
JWT_EXPIRES_IN=8h
